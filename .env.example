# =====================================================================
# ProcureHotel — variáveis de ambiente (exemplo)
# Copie para .env e ajuste antes de subir a stack.
# =====================================================================

# ---- App ----
APP_ENV=development
APP_NAME=ProcureHotel
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Supabase (Auth + DB + Storage) ----
# Obter no dashboard: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx               # safe em client
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx            # BACKEND ONLY, nunca expor
SUPABASE_JWKS_URL=                                  # auto-derivado se vazio
SUPABASE_STORAGE_BUCKET=ocr-uploads
STORAGE_BACKEND=supabase                            # supabase | local
SYNC_SUPABASE_USERS=true

# ---- Postgres (ligação direta ao Supabase DB) ----
# Formato: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# ou direct: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- Redis (opcional — Supabase também tem Upstash Redis) ----
REDIS_URL=redis://localhost:6379/0

# ---- Legacy self-hosted auth (apenas se NÃO usar Supabase) ----
JWT_SECRET=please-change-this-secret-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ---- OpenAI (GPT-5.5) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.1

# ---- OCR ----
OCR_ENGINE=docling           # docling | tesseract
TESSERACT_LANG=por+eng
OCR_UPLOAD_DIR=/tmp/procurehotel-uploads
MAX_UPLOAD_MB=25

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_APP_NAME=ProcureHotel
NEXT_PUBLIC_DEFAULT_LOCALE=pt-PT
