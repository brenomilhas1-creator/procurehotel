# =====================================================================
# ProcureHotel backend — env (exemplo)
# Copie para .env ou exporte antes de `uvicorn`.
# =====================================================================
APP_ENV=development
APP_NAME=ProcureHotel
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+psycopg://procurehotel:procurehotel@db:5432/procurehotel
REDIS_URL=redis://redis:6379/0

JWT_SECRET=please-change-this-secret-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.1

OCR_ENGINE=docling
TESSERACT_LANG=por+eng
OCR_UPLOAD_DIR=/tmp/procurehotel-uploads
MAX_UPLOAD_MB=25
